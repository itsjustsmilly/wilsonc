---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
}

const { title, date, description, tags } = Astro.props;

const formatted = date.toLocaleDateString('en-AU', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <div class="container">
    <header class="article-header">
      <p class="back"><a href="/essays">← All essays</a></p>
      <div class="meta">
        <time class="mono" datetime={date.toISOString()}>{formatted}</time>
        {tags.length > 0 && (
          <ul class="tags" aria-label="Tags">
            {tags.map(t => <li><span class="tag">{t}</span></li>)}
          </ul>
        )}
      </div>
      <h1>{title}</h1>
      <p class="description">{description}</p>
    </header>

    <div class="orange-rule"></div>

    <div class="prose">
      <slot />
    </div>
  </div>
</BaseLayout>

<style>
  .article-header { margin-bottom: var(--space-8); }

  .back {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-8);
    display: block;
  }
  .back a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }
  .back a:hover { color: var(--accent); opacity: 1; }

  .meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }

  time { color: var(--color-text-muted); }

  .tags {
    display: flex;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  h1 {
    font-size: clamp(var(--text-2xl), 5vw, var(--text-4xl));
    margin-bottom: var(--space-4);
    line-height: 1.1;
    letter-spacing: -0.03em;
    font-weight: 700;
  }

  .description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin: 0;
    max-width: 60ch;
    line-height: 1.55;
  }

  .orange-rule {
    width: 2.5rem;
    height: 2px;
    background: var(--accent);
    margin-block: var(--space-8);
  }

  @media (max-width: 640px) {
    h1 { font-size: var(--text-2xl); }
  }
</style>
