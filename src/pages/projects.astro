---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Projects"
  description="A selection of engineering and maker projects — electronics, CNC machines, data tools, and more."
>
  <div class="container">
    <header class="page-header">
      <h1>Projects</h1>
      <p class="subtitle">
        A collection of things I've built — hardware, software, and everything in between.
      </p>
    </header>

    {projects.length === 0 ? (
      <p class="empty">No projects yet — check back soon.</p>
    ) : (
      <ul class="grid" role="list" aria-label="Projects">
        {projects.map(project => (
          <li>
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              tags={project.data.tags}
              image={project.data.image}
              imageAlt={project.data.imageAlt}
              demoUrl={project.data.demoUrl}
              repoUrl={project.data.repoUrl}
              href={`/projects/${project.id}`}
            />
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>

<style>
  .page-header { margin-bottom: var(--space-12); }
  .page-header h1 { margin-bottom: var(--space-3); }
  .subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin: 0;
    max-width: 52ch;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .empty { color: var(--color-text-muted); }
</style>
