---
import { NAV_ITEMS } from '../config/nav';
import ThemeToggle from './ThemeToggle.astro';

const { pathname } = Astro.url;
function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header>
  <div class="container container--wide nav-inner">
    <a href="/" class="site-name" aria-label="Home">
      <span class="site-name-text">Wilson C.</span>
    </a>

    <ThemeToggle />

    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-label="Toggle navigation" />
    <label for="nav-toggle" class="nav-toggle-label" aria-hidden="true">
      <span></span><span></span><span></span>
    </label>

    <nav aria-label="Main navigation">
      <ul role="list">
        {NAV_ITEMS.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={['nav-link', { active: isActive(href) }]}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    height: 3.25rem;
  }

  .site-name {
    text-decoration: none;
    flex-shrink: 0;
    color: var(--color-text);
    opacity: 1;
  }
  .site-name:hover { opacity: 0.75; }
  .site-name-text {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  nav { margin-left: auto; }
  nav ul {
    display: flex;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.01em;
    transition: color var(--transition);
    position: relative;
  }
  .nav-link:hover {
    color: var(--color-text);
    opacity: 1;
  }
  .nav-link.active {
    color: var(--accent);
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: var(--space-3);
    right: var(--space-3);
    height: 2px;
    background: var(--accent);
    border-radius: 0;
  }

  .nav-toggle-input { display: none; }
  .nav-toggle-label { display: none; }

  @media (max-width: 640px) {
    .nav-toggle-label {
      display: flex;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      margin-left: auto;
      padding: var(--space-2);
    }
    .nav-toggle-label span {
      display: block;
      width: 20px;
      height: 1.5px;
      background: var(--color-text);
      transition: all var(--transition);
    }

    nav {
      position: absolute;
      top: 3.25rem;
      left: 0;
      right: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      display: none;
      margin-left: 0;
    }
    nav ul {
      flex-direction: column;
      padding: var(--space-4) var(--space-6);
      gap: var(--space-1);
    }

    .nav-toggle-input:checked ~ nav { display: block; }
  }
</style>
