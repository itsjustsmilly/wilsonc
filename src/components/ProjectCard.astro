---
interface Props {
  title: string;
  description: string;
  tags: string[];
  image?: string;
  imageAlt?: string;
  demoUrl?: string;
  repoUrl?: string;
  href: string;
}

const { title, description, tags, image, imageAlt, demoUrl, repoUrl, href } = Astro.props;
---

<article class="card">
  <div class="card-image">
    {image ? (
      <img src={image} alt={imageAlt ?? title} loading="lazy" />
    ) : (
      <div class="card-image-placeholder" aria-hidden="true">
        <span class="mono placeholder-label">No image</span>
      </div>
    )}
  </div>

  <div class="card-body">
    <h3 class="card-title">
      <a href={href} class="card-link">{title}</a>
    </h3>
    <p class="card-desc">{description}</p>

    <ul class="card-tags" aria-label="Technologies">
      {tags.map(tag => <li><span class="tag">{tag}</span></li>)}
    </ul>

    {(demoUrl || repoUrl) && (
      <div class="card-actions">
        {demoUrl && (
          <a href={demoUrl} target="_blank" rel="noopener noreferrer" class="link-btn">
            Live demo ↗
          </a>
        )}
        {repoUrl && (
          <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="link-btn link-btn--ghost">
            Source ↗
          </a>
        )}
      </div>
    )}
  </div>
</article>

<style>
  .card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    position: relative;
    transition: border-color var(--transition);
  }
  .card:hover {
    border-color: var(--accent);
  }

  .card-image {
    aspect-ratio: 16/9;
    background: var(--color-bg-subtle);
    overflow: hidden;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: repeating-linear-gradient(
      45deg,
      var(--color-bg-subtle),
      var(--color-bg-subtle) 8px,
      var(--color-bg) 8px,
      var(--color-bg) 16px
    );
  }
  .placeholder-label {
    color: var(--color-border);
  }

  .card-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .card-link {
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition);
  }
  .card-link::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  .card:hover .card-link { color: var(--accent); }

  .card-desc {
    color: var(--color-text-muted);
    font-size: var(--text-base);
    margin: 0;
    flex: 1;
    line-height: 1.55;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .card-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
  }

  .link-btn {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 500;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius);
    text-decoration: none;
    background: var(--accent);
    color: #fff;
    transition: opacity var(--transition);
  }
  .link-btn--ghost {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  .link-btn:hover { opacity: 0.8; }
</style>
